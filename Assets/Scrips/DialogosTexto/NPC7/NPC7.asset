  m_Name: NPC7
  m_EditorClassIdentifier: Assembly-CSharp::DialogNode
  Dialogo: "\u2014C\xF3mo odio a los no muertos. No son m\xE1s que una plaga. Lo
    \xFAnico bueno que tienen es su cuerpo. \xBFPor qu\xE9 no los matan a todos de
    una vez?"
  Options:
  - KarmaValue: -5
    SanidadValue: -5
    OptionText: "\u2014\xBFY por qu\xE9 no lo hace usted? \xBFAcaso piensa, idiota?"
    NextNode: {fileID: 0}
  - KarmaValue: 1
    SanidadValue: 0
    OptionText: "\u2014[Ignorar]"
    NextNode: {fileID: 0}
  - KarmaValue: 3
    SanidadValue: 5
    OptionText: "\u2014Eso es algo que se sale de mis manos."
    NextNode: {fileID: 0}
